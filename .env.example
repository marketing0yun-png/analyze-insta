# =====================================================================
# Meta SNS 트렌드 분석기 — 환경변수 (값 없이 키만. 실제 값은 .env.local)
# 참조: docs/08_SETUP.md §5, docs/06_AUTH_SECURITY.md §3
# ⚠️ .env.local 은 절대 커밋 금지. 시크릿은 Vercel/Supabase 시크릿에만.
# =====================================================================

# ---- 프론트 (공개 가능, RLS 전제) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- 서버 전용 (비밀 — 프론트 번들 금지) ----
SUPABASE_SERVICE_ROLE_KEY=
META_APP_ID=
META_APP_SECRET=
TOKEN_ENCRYPTION_KEY=        # Vault 미사용 시 토큰 암호화 키 (32바이트 권장)

# ---- Phase 3.5: 오너 토큰 폴백 (체험 유저 외부 수집 대행, D-025) ----
# 오너(운영자) 본인 장기 토큰. 미설정이면 체험 수집 비활성(개인 토큰만 수집 가능).
# 이 토큰으로는 외부 공개지표(Business Discovery)만 — 남의 노출·도달은 불가.
META_OWNER_TOKEN=
# (선택) 오너 ig_user_id. 미설정 시 런타임에 1회 자동 해석.
# META_OWNER_IG_USER_ID=

# ---- Phase 3: 마스터 콘솔 식별 (D-025) ----
# 마스터(/master, /api/master) 접근 허용 대상. 둘 다 비면 누구도 마스터 아님.
# 구글 로그인 후엔 이메일이 1순위. 익명단계엔 user_id(UUID)로 임시 지정.
MASTER_EMAILS=              # 쉼표 구분 (예: owner@gmail.com)
# MASTER_USER_IDS=          # 쉼표 구분 UUID (익명단계 임시)

# ---- Phase 2: AI 분석 (프로바이더 추상화, D-016) ----
# 활성 프로바이더. 현재 'gemini'만 구현 (향후 'claude').
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
# 출력 토큰 상한(호출별 미지정 시 기본). gemini-2.5-flash 최대 65536.
GEMINI_MAX_OUTPUT_TOKENS=65536
# 이미지 비전 분석(D-022). 기본 ON. 비용(이미지 토큰)을 줄이려면 off|false|0.
# AI_VISION=on

# Gemini = Vertex AI 경유. 인증은 아래 둘 중 하나:
#  (로컬) 서비스계정 키 파일 경로 — repo 밖에 보관할 것 (예: C:\Users\<you>\.gcp\key.json)
GOOGLE_APPLICATION_CREDENTIALS=
#  (Vercel 등 파일 없는 환경) 키 JSON 전체를 한 줄로
# GOOGLE_VERTEX_CREDENTIALS_JSON=
# project 는 명시하거나(권장) 키의 project_id 사용. location 미설정 시 global.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=global

# (정식 단계에 Claude 추가 시)
# ANTHROPIC_API_KEY=
