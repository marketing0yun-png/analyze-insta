# =====================================================================
# Meta SNS 트렌드 분석기 — 환경변수 (값 없이 키만. 실제 값은 .env.local)
# 참조: docs/08_SETUP.md §5, docs/06_AUTH_SECURITY.md §3
# ⚠️ .env.local 은 절대 커밋 금지. 시크릿은 Vercel/Supabase 시크릿에만.
# =====================================================================

# ---- 프론트 (공개 가능, RLS 전제) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- 서버 전용 (비밀 — 프론트 번들 금지) ----
SUPABASE_SERVICE_ROLE_KEY=
META_APP_ID=
META_APP_SECRET=
TOKEN_ENCRYPTION_KEY=        # Vault 미사용 시 토큰 암호화 키 (32바이트 권장)

# ---- Phase 2 ----
ANTHROPIC_API_KEY=
