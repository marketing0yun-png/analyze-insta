# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (시크릿). .env.example 은 커밋 허용
.env
.env.*
!.env.example

# supabase 로컬 산출물
/supabase/.branches
/supabase/.temp
.supabase

# 스캐폴딩 임시 (Windows 파일락 잔여)
/scaffold_tmp

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
